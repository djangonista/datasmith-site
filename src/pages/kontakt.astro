---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kontakt — DataSmith"
  description="Masz problem z danymi? Napisz — omówimy Twój przypadek."
>
  <div class="px-6 py-16">
    <div class="mx-auto max-w-5xl">
      <div class="mb-12">
        <span class="font-mono text-xs text-[#D97706]">// kontakt</span>
        <h1 class="mt-2 text-4xl font-bold text-[#E8E3D9]">Porozmawiajmy</h1>
        <p class="mt-3 max-w-xl text-[#8A8480]">
          Opisz problem — odpowiem w ciągu 24h. Pierwsze 30 minut rozmowy discovery jest bezpłatne.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2">
        <!-- Contact info -->
        <div class="flex flex-col gap-6">
          <div class="rounded border border-[#1E1E1E] bg-[#111111] p-6">
            <div class="mb-4 flex items-center gap-4">
              <img
                src="/images/pawel.jpg"
                alt="Paweł Kowalczyk"
                class="h-16 w-16 rounded-full border-2 border-[#D97706]/40 object-cover"
              />
              <h2 class="font-mono text-sm font-semibold text-[#E8E3D9]">Paweł Kowalczyk</h2>
            </div>
            <p class="mb-4 text-sm text-[#8A8480]">
              Analityk danych i problem solver. Specjalizuję się w automatyzacji procesów
              danych dla MŚP — Python, SQL, AI.
            </p>
            <div class="flex flex-col gap-3">
              <a
                href="mailto:pawel@datasmith.pl"
                class="flex items-center gap-3 font-mono text-sm text-[#8A8480] hover:text-[#D97706]"
              >
                <span class="text-[#D97706]">@</span>
                pawel@datasmith.pl
              </a>
              <a
                href="https://linkedin.com/in/pawelkowalczyk"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 font-mono text-sm text-[#8A8480] hover:text-[#D97706]"
              >
                <span class="text-[#D97706]">in</span>
                LinkedIn
              </a>
              <a
                href="https://x.com/plastyq"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 font-mono text-sm text-[#8A8480] hover:text-[#D97706]"
              >
                <span class="text-[#D97706]">X</span>
                @plastyq
              </a>
            </div>
          </div>

          <div class="rounded border border-[#1E1E1E] bg-[#111111] p-6">
            <h3 class="mb-3 font-mono text-sm font-semibold text-[#E8E3D9]">Jak wygląda współpraca?</h3>
            <ol class="flex flex-col gap-2">
              {[
                'Discovery call (30 min, bezpłatnie) — opisujesz problem',
                'Otrzymujesz brief + wycenę w ciągu 48h',
                'Buduję rozwiązanie iteracyjnie — z feedbackiem',
                'Dostajesz gotowe narzędzie + dokumentację',
              ].map((step, i) => (
                <li class="flex gap-3 text-sm text-[#8A8480]">
                  <span class="shrink-0 font-mono text-[#D97706]">{String(i + 1).padStart(2, '0')}.</span>
                  {step}
                </li>
              ))}
            </ol>
          </div>
        </div>

        <!-- Contact form -->
        <div class="rounded border border-[#1E1E1E] bg-[#111111] p-6">
          <h2 class="mb-6 font-mono text-sm font-semibold text-[#E8E3D9]">Napisz mi</h2>
          <form
            action="https://formspree.io/f/xwvndevk"
            method="POST"
            class="flex flex-col gap-4"
          >
            <input type="hidden" name="_subject" value="Nowe zapytanie — datasmith.pl" />
            <div>
              <label class="mb-1.5 block font-mono text-xs text-[#8A8480]">Imię i firma</label>
              <input
                type="text"
                name="name"
                required
                class="w-full rounded border border-[#1E1E1E] bg-[#0C0C0C] px-4 py-2.5 font-mono text-sm text-[#E8E3D9] placeholder-[#8A8480] focus:border-[#D97706] focus:outline-none"
                placeholder="Jan Kowalski, Firma Sp. z o.o."
              />
            </div>
            <div>
              <label class="mb-1.5 block font-mono text-xs text-[#8A8480]">Email</label>
              <input
                type="email"
                name="email"
                required
                class="w-full rounded border border-[#1E1E1E] bg-[#0C0C0C] px-4 py-2.5 font-mono text-sm text-[#E8E3D9] placeholder-[#8A8480] focus:border-[#D97706] focus:outline-none"
                placeholder="jan@firma.pl"
              />
            </div>
            <div>
              <label class="mb-1.5 block font-mono text-xs text-[#8A8480]">Opisz problem</label>
              <textarea
                name="message"
                required
                rows="5"
                class="w-full rounded border border-[#1E1E1E] bg-[#0C0C0C] px-4 py-2.5 font-mono text-sm text-[#E8E3D9] placeholder-[#8A8480] focus:border-[#D97706] focus:outline-none resize-none"
                placeholder="Co robisz ręcznie, co zajmuje za dużo czasu? Jaki system używasz?..."
              ></textarea>
            </div>
            <button
              type="submit"
              class="rounded bg-[#D97706] px-6 py-3 font-mono text-sm font-semibold text-[#0C0C0C] transition-all hover:bg-[#F59E0B]"
            >
              Wyślij wiadomość
            </button>
            <p class="font-mono text-xs text-[#8A8480]">
              Odpowiadam w ciągu 24h w dni robocze.
            </p>
          </form>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
