---
---

<section id="heroSection" class="relative overflow-hidden px-6 py-24 md:py-36" style="min-height: 70vh;">
  <!-- Radar canvas background -->
  <canvas id="radarCanvas" class="pointer-events-none absolute inset-0 h-full w-full"></canvas>

  <div class="relative z-10 mx-auto max-w-5xl">
    <!-- Label -->
    <div class="hero-item mb-6 inline-flex items-center gap-2 rounded-full border border-[#D97706]/20 bg-[#D97706]/5 px-3 py-1" style="--hero-delay: 0ms">
      <span class="blip-dot h-1.5 w-1.5 rounded-full bg-[#D97706]"></span>
      <span class="font-mono text-xs text-[#D97706]">Decision Intelligence dla MŚP</span>
    </div>

    <!-- Headline -->
    <h1 class="hero-item max-w-3xl text-4xl font-bold leading-tight text-[#E8E3D9] md:text-5xl lg:text-6xl" style="--hero-delay: 80ms">
      <em class="not-italic text-[#D97706]">Widoczność</em><br />
      zamiast zgadywania
    </h1>

    <!-- Subheadline -->
    <p class="hero-item mt-6 max-w-2xl text-lg leading-relaxed text-[#8A8480] md:text-xl" style="--hero-delay: 160ms">
      Dane, które mówią Twoim językiem. Dla prezesów MŚP produkcyjnych,
      którzy chcą widzieć na czym tracą i na czym zarabiają. Na Twoich danych. Bez wymiany systemu.
    </p>

    <!-- Case teaser -->
    <div class="hero-item mt-8 max-w-lg rounded border border-[#1E1E1E] bg-[#111111] p-5" style="--hero-delay: 200ms">
      <p class="mb-2 text-sm text-[#8A8480]">Produkt wyglądał na nierentowny. Do wycofania.</p>
      <p class="mb-1 text-lg"><span class="font-bold text-red-400">-130 zł</span> <span class="text-sm text-[#8A8480]">na każdej sztuce wg rachunku kosztów</span></p>
      <p class="mb-3 text-lg"><span class="font-bold text-[#27c93f]">+170 zł</span> <span class="text-sm text-[#8A8480]">czystego przerobu po zmianie perspektywy</span></p>
      <p class="mt-2 border-t border-[#1E1E1E] pt-2 text-sm font-semibold text-[#E8E3D9]">Decyzja: zamiast wycofać, podwoić podaż. Większe zyski.</p>
    </div>

    <!-- CTAs -->
    <div class="hero-item mt-8 flex flex-wrap items-center gap-4" style="--hero-delay: 280ms">
      <a
        href="#quiz"
        class="rounded bg-[#D97706] px-6 py-3 font-mono text-sm font-semibold text-[#0C0C0C] transition-all hover:bg-[#F59E0B] hover:shadow-[0_0_20px_rgba(217,119,6,0.3)]"
      >
        Sprawdź swoją firmę
      </a>
      <a
        href="#problem"
        class="rounded border border-[#1E1E1E] px-6 py-3 font-mono text-sm text-[#8A8480] transition-all hover:border-[#E8E3D9]/20 hover:text-[#E8E3D9]"
      >
        Jak to działa &darr;
      </a>
    </div>

    <!-- Stats -->
    <div class="hero-item mt-16 flex flex-wrap gap-8 pt-10" style="--hero-delay: 360ms">
      <div>
        <p class="stat-num text-[#D97706]">-130 &rarr; +170</p>
        <p class="stat-desc">Jedna zmiana perspektywy</p>
      </div>
      <div>
        <p class="stat-num text-[#E8E3D9]">16 lat</p>
        <p class="stat-desc">W produkcji, z ERP i SQL</p>
      </div>
      <div>
        <p class="stat-num text-[#E8E3D9]">2 tygodnie</p>
        <p class="stat-desc">Do pierwszego raportu</p>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Fade-in tekstu przy ładowaniu strony (stagger) ── */
  .hero-item {
    opacity: 0;
    transform: translateY(10px);
    animation: heroFadeUp 0.6s ease forwards;
    animation-delay: var(--hero-delay, 0ms);
  }

  @keyframes heroFadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Stats formatting (matching radar demo) ── */
  .stat-num {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
  }
  .stat-desc {
    margin-top: 0.25rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    color: #8A8480;
    letter-spacing: 0.05em;
  }

  /* Badge dot blink */
  @keyframes blipBlink {
    0%, 100% { opacity: 1; box-shadow: 0 0 6px #D97706; }
    50%       { opacity: 0.3; box-shadow: none; }
  }
  .blip-dot { animation: blipBlink 2.4s ease-in-out infinite; }

  /* Respektuj prefer-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-item { animation: none; opacity: 1; transform: none; }
    .blip-dot  { animation: none; }
    #radarCanvas { display: none; }
  }
</style>

<script is:inline>
(function () {
  const SIGNAL_DEFS = [
    ['ERP',             0.25, 0.38],
    ['SQL Server',      0.72, 0.58],
    ['KPI',             1.20, 0.44],
    ['Decyzja',         1.68, 0.70],
    ['Automatyzacja',   2.20, 0.52],
    ['Raport PDF',      2.75, 0.34],
    ['OEE',             3.30, 0.65],
    ['Dane → Decyzje', 3.85, 0.28],
    ['Python',          4.40, 0.56],
    ['MCP / AI',        4.95, 0.76],
    ['ETL',             5.50, 0.42],
    ['Mostek danych',   6.00, 0.62],
  ];

  const signals = SIGNAL_DEFS.map(([label, angle, baseDist]) => ({
    label, angle, baseDist,
    level: 0,
    maxLevel: 4 + Math.floor(Math.random() * 3),
    dist: baseDist,
    lit: 0,
    litMax: 130,
    fading: false,
    fadeAlpha: 1,
  }));

  const pulses = [];
  const canvas = document.getElementById('radarCanvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const heroEl = document.getElementById('heroSection');

  let W, H, CX, CY, R;

  function resize() {
    W = canvas.width  = heroEl.clientWidth;
    H = canvas.height = heroEl.clientHeight;
    // Radar centered in the right portion (text is left-aligned)
    CX = W * 0.72;
    CY = H * 0.50;
    R  = Math.hypot(Math.max(CX, W - CX), Math.max(CY, H - CY));
  }

  let sweepAngle = -Math.PI / 2;
  const SWEEP_SPEED = 0.008;
  const TRAIL = Math.PI * 0.55;
  let rotations = 0;

  function norm(a) { return ((a % (Math.PI * 2)) + Math.PI * 2) % (Math.PI * 2); }
  function angDiff(sweep, sig) { return norm(norm(sweep) - norm(sig)); }
  function rgba(r, g, b, a) { return `rgba(${r},${g},${b},${a.toFixed(3)})`; }

  const AMBER  = [245, 158, 11];
  const AMBERL = [251, 191, 36];

  function blipXY(s) {
    const d = Math.min(s.dist, 0.92);
    const refR = Math.min(W, H) * 0.42;
    return {
      x: CX + Math.cos(s.angle) * d * refR,
      y: CY + Math.sin(s.angle) * d * refR,
    };
  }

  function onNewRotation() {
    signals.forEach(s => { if (s.level > 0) s.fading = true; });
    setTimeout(() => {
      signals.forEach(s => {
        if (s.fading) {
          s.lit = 0; s.fading = false; s.fadeAlpha = 1;
          s.level = (s.level + 1) % (s.maxLevel + 1);
          s.dist = s.baseDist + (s.level / s.maxLevel) * 0.18;
        }
      });
    }, 600);
  }

  function drawGrid() {
    const refR = Math.min(W, H) * 0.42;
    for (let i = 1; i <= 5; i++) {
      ctx.beginPath();
      ctx.arc(CX, CY, (i / 5) * refR, 0, Math.PI * 2);
      ctx.strokeStyle = rgba(...AMBER, 0.07);
      ctx.lineWidth = 1;
      ctx.stroke();
    }
    for (let i = 0; i < 8; i++) {
      const a = (i / 8) * Math.PI * 2;
      ctx.beginPath();
      ctx.moveTo(CX, CY);
      ctx.lineTo(CX + Math.cos(a) * R, CY + Math.sin(a) * R);
      ctx.strokeStyle = rgba(...AMBER, 0.04);
      ctx.lineWidth = 1;
      ctx.stroke();
    }
    for (let i = 0; i < 72; i++) {
      const a = (i / 72) * Math.PI * 2;
      const isMain = i % 9 === 0;
      const r0 = refR * (isMain ? 0.93 : 0.96);
      ctx.beginPath();
      ctx.moveTo(CX + Math.cos(a) * r0, CY + Math.sin(a) * r0);
      ctx.lineTo(CX + Math.cos(a) * refR, CY + Math.sin(a) * refR);
      ctx.strokeStyle = rgba(...AMBER, isMain ? 0.28 : 0.1);
      ctx.lineWidth = isMain ? 1.2 : 0.6;
      ctx.stroke();
    }
  }

  function drawSweep() {
    for (let i = 0; i < 80; i++) {
      const t  = i / 80;
      const t1 = (i + 1) / 80;
      const a0 = sweepAngle - TRAIL * (1 - t);
      const a1 = sweepAngle - TRAIL * (1 - t1);
      ctx.beginPath();
      ctx.moveTo(CX, CY);
      ctx.arc(CX, CY, R, a0, a1);
      ctx.closePath();
      ctx.fillStyle = rgba(...AMBER, t * t * 0.18);
      ctx.fill();
    }
    ctx.beginPath();
    ctx.moveTo(CX, CY);
    ctx.lineTo(CX + Math.cos(sweepAngle) * R, CY + Math.sin(sweepAngle) * R);
    const lg = ctx.createLinearGradient(
      CX, CY,
      CX + Math.cos(sweepAngle) * R, CY + Math.sin(sweepAngle) * R
    );
    lg.addColorStop(0,   rgba(...AMBERL, 0.9));
    lg.addColorStop(0.6, rgba(...AMBER,  0.5));
    lg.addColorStop(1,   rgba(...AMBER,  0));
    ctx.strokeStyle = lg;
    ctx.lineWidth = 1.8;
    ctx.shadowBlur = 12;
    ctx.shadowColor = rgba(...AMBER, 0.8);
    ctx.stroke();
    ctx.shadowBlur = 0;

    ctx.beginPath();
    ctx.arc(CX, CY, 4, 0, Math.PI * 2);
    ctx.fillStyle = rgba(...AMBERL, 1);
    ctx.shadowBlur = 14;
    ctx.shadowColor = rgba(...AMBER, 1);
    ctx.fill();
    ctx.shadowBlur = 0;
  }

  function drawBlips() {
    signals.forEach(s => {
      const diff = angDiff(sweepAngle, s.angle);
      if (diff < 0.07 && !s.fading) {
        s.lit = s.litMax;
        const { x, y } = blipXY(s);
        pulses.push({ x, y, r: 0, maxR: 28 + s.level * 6, t: 0 });
      }
      if (s.fading) s.fadeAlpha = Math.max(0, s.fadeAlpha - 0.018);
      if (s.lit <= 0 && !s.fading) return;

      const baseAlpha = s.fading ? s.fadeAlpha : Math.min(1, (s.lit / s.litMax) * 1.5);
      s.lit = Math.max(0, s.lit - 1);
      const { x, y } = blipXY(s);

      if (s.level > 0) {
        const arcSpan = (s.level / s.maxLevel) * Math.PI * 1.5;
        ctx.beginPath();
        ctx.arc(x, y, 14 + s.level * 2.5, -Math.PI / 2, -Math.PI / 2 + arcSpan);
        ctx.strokeStyle = rgba(...AMBER, baseAlpha * 0.55);
        ctx.lineWidth = 2;
        ctx.shadowBlur = 6;
        ctx.shadowColor = rgba(...AMBER, 0.4);
        ctx.stroke();
        ctx.shadowBlur = 0;
      }

      ctx.beginPath();
      ctx.arc(x, y, 8 + (1 - s.lit / s.litMax) * 18, 0, Math.PI * 2);
      ctx.strokeStyle = rgba(...AMBER, baseAlpha * 0.28);
      ctx.lineWidth = 1;
      ctx.stroke();

      const gr = ctx.createRadialGradient(x, y, 0, x, y, 20);
      gr.addColorStop(0, rgba(...AMBER, baseAlpha * 0.4));
      gr.addColorStop(1, rgba(...AMBER, 0));
      ctx.beginPath();
      ctx.arc(x, y, 20, 0, Math.PI * 2);
      ctx.fillStyle = gr;
      ctx.fill();

      const dotR = 3 + s.level * 0.8;
      ctx.beginPath();
      ctx.arc(x, y, dotR, 0, Math.PI * 2);
      ctx.fillStyle = rgba(...AMBERL, baseAlpha * 0.9);
      ctx.shadowBlur = 14;
      ctx.shadowColor = rgba(...AMBER, baseAlpha);
      ctx.fill();
      ctx.shadowBlur = 0;

      if (baseAlpha > 0.07) {
        const fs = Math.max(9, Math.min(12, W * 0.01));
        ctx.font = `400 ${fs}px 'JetBrains Mono', monospace`;
        const lx = x > CX ? x + dotR + 8 : x - dotR - 8;
        ctx.textAlign = x > CX ? 'left' : 'right';
        ctx.fillStyle = rgba(...AMBER, baseAlpha * 0.85);
        ctx.fillText(s.label, lx, y - 4);
        if (s.level > 0) {
          ctx.font = `300 ${Math.max(7, Math.min(9, W * 0.009))}px 'JetBrains Mono', monospace`;
          ctx.fillStyle = rgba(...AMBERL, baseAlpha * 0.6);
          ctx.fillText(`+${s.level}`, lx, y + 10);
        }
      }
    });
  }

  function drawPulses() {
    for (let i = pulses.length - 1; i >= 0; i--) {
      const p = pulses[i];
      p.t += 0.045;
      p.r = p.maxR * p.t;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.strokeStyle = rgba(...AMBER, (1 - p.t) * 0.5);
      ctx.lineWidth = 1.5;
      ctx.stroke();
      if (p.t >= 1) pulses.splice(i, 1);
    }
  }

  function frame() {
    ctx.clearRect(0, 0, W, H);
    drawGrid();
    drawSweep();
    drawBlips();
    drawPulses();

    const prev = sweepAngle;
    sweepAngle += SWEEP_SPEED;
    if (sweepAngle > Math.PI) sweepAngle -= Math.PI * 2;
    if (prev < 0 && sweepAngle >= 0) {
      rotations++;
      onNewRotation();
    }
    requestAnimationFrame(frame);
  }

  window.addEventListener('resize', resize);
  resize();
  frame();
})();
</script>
