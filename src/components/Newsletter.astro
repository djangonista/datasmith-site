---
---

<section id="newsletter" class="px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <div class="rounded border border-[#D97706]/20 bg-[#111111] p-8 md:p-12">
      <div class="mx-auto max-w-xl text-center">
        <span class="font-mono text-xs text-[#D97706]">// newsletter</span>
        <h2 class="mt-3 text-2xl font-bold text-[#E8E3D9] md:text-3xl">
          Build in Public — co tydzień
        </h2>
        <p class="mt-3 text-[#8A8480]">
          Wysyłam co tydzień: konkretne rozwiązania problemów z danymi, demo automatyzacji
          i case studies z anonimizowanych projektów.
        </p>

        <form id="ac-form" class="mt-8 flex flex-col gap-3" novalidate>
          <input type="hidden" name="u" value="9" />
          <input type="hidden" name="f" value="9" />
          <input type="hidden" name="s" value="" />
          <input type="hidden" name="c" value="0" />
          <input type="hidden" name="m" value="0" />
          <input type="hidden" name="act" value="sub" />
          <input type="hidden" name="v" value="2" />
          <input type="hidden" name="or" value="c66d00cf-cfac-4660-8ee7-95d797e04447" />

          <div class="flex flex-col gap-3 sm:flex-row">
            <input
              type="text"
              name="firstname"
              placeholder="Imię"
              class="w-full rounded border border-[#1E1E1E] bg-[#0C0C0C] px-4 py-2.5 font-mono text-sm text-[#E8E3D9] placeholder-[#8A8480] focus:border-[#D97706] focus:outline-none sm:w-36"
            />
            <input
              type="email"
              name="email"
              required
              placeholder="twój@email.pl"
              class="flex-1 rounded border border-[#1E1E1E] bg-[#0C0C0C] px-4 py-2.5 font-mono text-sm text-[#E8E3D9] placeholder-[#8A8480] focus:border-[#D97706] focus:outline-none"
            />
            <button
              type="submit"
              id="ac-btn"
              class="rounded bg-[#D97706] px-6 py-2.5 font-mono text-sm font-semibold text-[#0C0C0C] transition-all hover:bg-[#F59E0B] disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Zapisz się
            </button>
          </div>
          <label class="flex items-start gap-2 text-left">
            <input
              type="checkbox"
              id="ac-consent"
              required
              class="mt-0.5 shrink-0 accent-[#D97706]"
            />
            <span class="font-mono text-xs text-[#8A8480]">
              Chcę być na liście — rozumiem, że mogę zrezygnować w każdej chwili.
            </span>
          </label>
        </form>

        <div id="ac-success" class="mt-8 hidden">
          <p class="font-mono text-sm text-[#D97706]">✓ Zapisano.</p>
          <p class="mt-1 font-mono text-xs text-[#8A8480]">Sprawdź skrzynkę — wyślę potwierdzenie.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('ac-form') as HTMLFormElement;
  const btn = document.getElementById('ac-btn') as HTMLButtonElement;
  const successDiv = document.getElementById('ac-success') as HTMLDivElement;

  function showSuccess() {
    form.style.display = 'none';
    successDiv.classList.remove('hidden');
  }

  // AC callbacks — called by server response JS
  (window as any)._show_thank_you = showSuccess;
  (window as any)._show_error = function() {
    btn.disabled = false;
    btn.textContent = 'Zapisz się';
    alert('Coś poszło nie tak. Spróbuj ponownie.');
  };

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const emailInput = form.querySelector<HTMLInputElement>('[name="email"]')!;
    const consent = document.getElementById('ac-consent') as HTMLInputElement;
    if (!emailInput.value || !emailInput.value.includes('@')) {
      emailInput.focus();
      return;
    }
    if (!consent.checked) {
      consent.focus();
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Zapisuję...';

    const params: string[] = [];
    form.querySelectorAll('input').forEach((input) => {
      if (input.name) {
        params.push(encodeURIComponent(input.name) + '=' + encodeURIComponent(input.value));
      }
    });

    const script = document.createElement('script');
    script.onerror = () => setTimeout(showSuccess, 500);
    script.src = `https://pawelkowalczyk.activehosted.com/proc.php?${params.join('&')}&jsonp=true`;
    document.head.appendChild(script);
  });
</script>
