---
const cases = [
  {
    id: 'stalab',
    label: '01 / Narzędzie bazodanowe',
    title: 'Dane uwięzione w bazie. 100 000 pomiarów.',
    client: 'Firma produkcyjna (anonimizacja)',
    problem:
      'Stary program przestał działać po zmianie serwera. Kontrolerzy jakości musieli prosić IT o każde sprawdzenie. Albo nie sprawdzali wcale.',
    solution:
      'Dedykowana aplikacja z interfejsem graficznym. Filtr po dacie, produkcie, serii. Jeden plik .exe, zero instalacji.',
    result: '100 000 wyników kontroli jakości dostępnych natychmiast. Przy reklamacji odpowiedź w 10 sekund, nie w 2 dniach.',
    tags: ['Python', 'tkinter', 'SQL Server', 'PyInstaller'],
  },
  {
    id: 'wyciagi',
    label: '02 / Automatyzacja',
    title: 'Wyciągi bankowe: 3h → 8 sekund',
    client: 'Biuro rachunkowe (walidacja)',
    problem:
      'Co miesiąc 3 godziny na ręczne przepisywanie wyciągów bankowych w PLN i EUR. Podatne na błędy i nikomu niepotrzebne.',
    solution:
      'Automat wczytuje plik z banku, przelicza kursy walut i generuje gotowy arkusz do zaksięgowania.',
    result: '8 sekund zamiast 3 godzin. Identyczne wyniki jak ręcznie, zweryfikowane na rzeczywistych danych.',
    tags: ['Python', 'PDF parsing', 'NBP API', 'Excel'],
  },
  {
    id: 'mt940',
    label: '03 / Mostek danych',
    title: 'Automatyczny import wyciągów do ERP',
    client: 'Firma produkcyjna (anonimizacja)',
    problem:
      'Bank i system ERP firmy mówiły różnymi językami. Import wyciągów wymagał ręcznej pracy co miesiąc.',
    solution:
      'Konwerter formatu bankowego do formatu importu systemu ERP. Raz skonfigurowany, działa na stałe.',
    result: 'Automatyczny import. Zero ręcznej pracy, zero błędów przepisywania.',
    tags: ['Python', 'MT940', 'ERP', 'BGK'],
  },
];
---

<section id="case-studies" class="px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <!-- Header -->
    <div class="mb-12">
      <span class="font-mono text-xs text-[#D97706]">// realizacje</span>
      <h2 class="mt-2 text-3xl font-bold text-[#E8E3D9] md:text-4xl">
        Problemy, które już rozwiązałem
      </h2>
      <p class="mt-3 text-[#8A8480]">
        Realne dane, realne firmy. Nazwy zanonimizowane.
      </p>
    </div>

    <!-- Cases -->
    <div class="flex flex-col gap-6">
      {cases.map((c) => (
        <div data-animate class="rounded border border-[#1E1E1E] bg-[#111111] p-6 transition-all duration-200 hover:-translate-y-1 hover:border-[#D97706]/30 hover:shadow-[0_4px_24px_rgba(217,119,6,0.07)]">
          <div class="flex flex-col gap-6 md:flex-row md:gap-10">
            <!-- Left -->
            <div class="md:w-1/3">
              <span class="font-mono text-xs text-[#D97706]">{c.label}</span>
              <h3 class="mt-2 text-xl font-semibold text-[#E8E3D9]">{c.title}</h3>
              <p class="mt-1 font-mono text-xs text-[#8A8480]">{c.client}</p>
              <div class="mt-4 flex flex-wrap gap-1.5">
                {c.tags.map((tag) => (
                  <span class="rounded bg-[#0C0C0C] px-2 py-0.5 font-mono text-xs text-[#8A8480]">
                    {tag}
                  </span>
                ))}
              </div>
            </div>

            <!-- Right -->
            <div class="flex flex-1 flex-col gap-4">
              <div>
                <p class="mb-1 font-mono text-xs text-[#8A8480] uppercase tracking-wider">Problem</p>
                <p class="text-sm leading-relaxed text-[#8A8480]">{c.problem}</p>
              </div>
              <div>
                <p class="mb-1 font-mono text-xs text-[#8A8480] uppercase tracking-wider">Rozwiązanie</p>
                <p class="text-sm leading-relaxed text-[#8A8480]">{c.solution}</p>
              </div>
              <div class="rounded bg-[#0C0C0C] px-4 py-3">
                <p class="font-mono text-xs text-[#D97706] uppercase tracking-wider">Wynik</p>
                <p class="mt-1 text-sm font-semibold text-[#E8E3D9]">{c.result}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
