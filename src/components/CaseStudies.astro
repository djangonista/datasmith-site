---
const cases = [
  {
    id: 'stalab',
    label: '01 / Narzędzie bazodanowe',
    title: 'Edytor 113k próbek laboratoryjnych',
    client: 'Firma produkcyjna (anonimizacja)',
    problem:
      'Stary program do obsługi bazy próbek przestał działać po migracji serwera SQL. Dane musiały być edytowane ręcznie przez programistę — każda zmiana = ticket + oczekiwanie.',
    solution:
      'Dedykowana apka Python + tkinter z filtrowaniem, edycją i zapisem. Jeden plik .exe (12 MB), zero instalacji u klienta.',
    result: '113k próbek dostępnych natychmiast, samodzielna obsługa przez pracownika',
    tags: ['Python', 'tkinter', 'SQL Server', 'PyInstaller'],
  },
  {
    id: 'wyciagi',
    label: '02 / Automatyzacja',
    title: 'Wyciągi bankowe: 3h → 8 sekund',
    client: 'Biuro rachunkowe (walidacja)',
    problem:
      'Ręczne przepisywanie wyciągów bankowych PLN + EUR do arkusza. Każdy miesiąc to 2–3 godziny pracy — żmudne, podatne na błędy, nikomu nie potrzebne.',
    solution:
      'Automat Python: wczytuje PDF wyciągu, parsuje transakcje, pobiera kursy NBP, generuje gotowy arkusz Excel.',
    result: '8 sekund zamiast 3 godzin. Identyczne wyniki jak ręcznie — zweryfikowane',
    tags: ['Python', 'PDF parsing', 'NBP API', 'Excel'],
  },
  {
    id: 'mt940',
    label: '03 / Mostek danych',
    title: 'Konwerter MT940 → ERP',
    client: 'Firma produkcyjna (anonimizacja)',
    problem:
      'Bank eksportuje wyciągi w formacie MT940. System ERP firmy oczekuje innego formatu. Import ręczny = godziny miesięcznie.',
    solution:
      'Konwerter MT940 → format importu systemu ERP klienta. Testowany na rzeczywistych danych produkcyjnych.',
    result: 'Automatyczny import — zero ręcznej pracy, zero błędów przepisywania',
    tags: ['Python', 'MT940', 'ERP', 'BGK'],
  },
];
---

<section id="case-studies" class="px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <!-- Header -->
    <div class="mb-12">
      <span class="font-mono text-xs text-[#D97706]">// realizacje</span>
      <h2 class="mt-2 text-3xl font-bold text-[#E8E3D9] md:text-4xl">
        Problemy, które już rozwiązałem
      </h2>
      <p class="mt-3 text-[#8A8480]">
        Realne dane, realne firmy — nazwy zanonimizowane.
      </p>
    </div>

    <!-- Cases -->
    <div class="flex flex-col gap-6">
      {cases.map((c) => (
        <div class="rounded border border-[#1E1E1E] bg-[#111111] p-6 transition-all hover:border-[#D97706]/20">
          <div class="flex flex-col gap-6 md:flex-row md:gap-10">
            <!-- Left -->
            <div class="md:w-1/3">
              <span class="font-mono text-xs text-[#D97706]">{c.label}</span>
              <h3 class="mt-2 text-xl font-semibold text-[#E8E3D9]">{c.title}</h3>
              <p class="mt-1 font-mono text-xs text-[#8A8480]">{c.client}</p>
              <div class="mt-4 flex flex-wrap gap-1.5">
                {c.tags.map((tag) => (
                  <span class="rounded bg-[#0C0C0C] px-2 py-0.5 font-mono text-xs text-[#8A8480]">
                    {tag}
                  </span>
                ))}
              </div>
            </div>

            <!-- Right -->
            <div class="flex flex-1 flex-col gap-4">
              <div>
                <p class="mb-1 font-mono text-xs text-[#8A8480] uppercase tracking-wider">Problem</p>
                <p class="text-sm leading-relaxed text-[#8A8480]">{c.problem}</p>
              </div>
              <div>
                <p class="mb-1 font-mono text-xs text-[#8A8480] uppercase tracking-wider">Rozwiązanie</p>
                <p class="text-sm leading-relaxed text-[#8A8480]">{c.solution}</p>
              </div>
              <div class="rounded bg-[#0C0C0C] px-4 py-3">
                <p class="font-mono text-xs text-[#D97706] uppercase tracking-wider">Wynik</p>
                <p class="mt-1 text-sm font-semibold text-[#E8E3D9]">{c.result}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
