---
---

<section class="relative overflow-hidden px-6 py-24 md:py-36">
  <!-- Subtle grid background -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.03]"
    style="background-image: linear-gradient(#D97706 1px, transparent 1px), linear-gradient(90deg, #D97706 1px, transparent 1px); background-size: 40px 40px;"
  ></div>

  <div class="relative mx-auto max-w-5xl">
    <!-- Label -->
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#D97706]/20 bg-[#D97706]/5 px-3 py-1">
      <span class="h-1.5 w-1.5 rounded-full bg-[#D97706]"></span>
      <span class="font-mono text-xs text-[#D97706]">Problem Solver + AI</span>
    </div>

    <!-- Headline -->
    <h1 class="max-w-3xl text-4xl font-bold leading-tight text-[#E8E3D9] md:text-5xl lg:text-6xl">
      Każdy problem z danymi<br />
      <span class="text-[#D97706]">ma rozwiązanie.</span>
    </h1>

    <!-- Subheadline -->
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-[#8A8480] md:text-xl">
      Łączę SQL, Python i AI — buduję narzędzia dopasowane do Twojego systemu.
      Automatyzuję powtarzalne procesy danych dla&nbsp;MŚP i&nbsp;firm produkcyjnych.
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-wrap items-center gap-4">
      <a
        href="/#uslugi"
        class="rounded bg-[#D97706] px-6 py-3 font-mono text-sm font-semibold text-[#0C0C0C] transition-all hover:bg-[#F59E0B] hover:shadow-[0_0_20px_rgba(217,119,6,0.3)]"
      >
        Sprawdź usługi
      </a>
      <a
        href="/blog"
        class="rounded border border-[#1E1E1E] px-6 py-3 font-mono text-sm text-[#8A8480] transition-all hover:border-[#E8E3D9]/20 hover:text-[#E8E3D9]"
      >
        Czytaj blog →
      </a>
    </div>

    <!-- Stats / Social proof -->
    <div class="mt-16 flex flex-wrap gap-8 border-t border-[#1E1E1E] pt-10">
      <div>
        <p class="font-mono text-2xl font-bold text-[#E8E3D9]">3h → 8s</p>
        <p class="mt-1 font-mono text-xs text-[#8A8480]">Automatyzacja wyciągów bankowych</p>
      </div>
      <div>
        <p class="font-mono text-2xl font-bold text-[#E8E3D9]">113k</p>
        <p class="mt-1 font-mono text-xs text-[#8A8480]">Próbek w narzędziu bazodanowym</p>
      </div>
      <div>
        <p class="font-mono text-2xl font-bold text-[#E8E3D9]">SQL + Python + AI</p>
        <p class="mt-1 font-mono text-xs text-[#8A8480]">Stack dopasowany do problemu</p>
      </div>
    </div>
  </div>
</section>
