---
interface Props {
  size?: 'sm' | 'md' | 'lg';
}
const { size = 'md' } = Astro.props;
const sizeClass = { sm: 'text-base', md: 'text-lg', lg: 'text-2xl' }[size];
---

<span class={`inline-flex items-baseline font-mono font-bold leading-none ${sizeClass}`}>
  <span class="text-[#8A8480]">&lt;</span><span class="text-[#D97706]">DS</span><span class="text-[#8A8480]">&nbsp;/&gt;</span>
</span>
