---
import { faqs } from '../data/faqs';
---

<section id="faq" class="px-6 py-24 border-t border-[#1E1E1E]">
  <div class="mx-auto max-w-3xl">
    <div class="mb-12">
      <span class="font-mono text-xs text-[#D97706]">// faq</span>
      <h2 class="mt-2 text-3xl font-bold text-[#E8E3D9] md:text-4xl">
        Częste pytania
      </h2>
    </div>

    <div class="space-y-4">
      {faqs.map((faq) => (
        <details
          data-animate
          class="group rounded border border-[#1E1E1E] bg-[#111111] transition-all hover:border-[#D97706]/30"
        >
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 font-mono text-sm font-semibold text-[#E8E3D9] [&::-webkit-details-marker]:hidden">
            {faq.question}
            <span class="shrink-0 text-[#D97706] transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="px-5 pb-5 text-sm leading-relaxed text-[#8A8480]">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
