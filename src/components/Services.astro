---
const services = [
  {
    id: 'raport-na-automacie',
    title: 'Raport na Automacie',
    tagline: 'Raporty zarządcze bez ręcznego zbierania danych',
    price: '2 000 PLN + 400/mies',
    description:
      'Łączę się z Twoim ERP lub bazą danych. Agregacje, wykresy, porównania rok do roku. Profesjonalny PDF z logo firmy gotowy automatycznie każdego ranka.',
    tags: ['Python', 'SQL', 'LaTeX', 'PDF'],
    ready: true,
  },
  {
    id: 'mostek-danych',
    title: 'Mostek Danych',
    tagline: 'Łączę systemy, które nie rozmawiają ze sobą',
    price: '1 000–2 000 PLN',
    description:
      'Twój bank eksportuje dane w innym formacie niż Twój ERP? Buduję mostek raz. Potem działa na stałe. Bez ręcznego przepisywania, bez błędów.',
    tags: ['Python', 'ETL', 'API'],
    ready: true,
  },
  {
    id: 'narzedzie-bazodanowe',
    title: 'Narzędzie Bazodanowe',
    tagline: 'Twoje dane pod kontrolą, bez działu IT',
    price: '2 000–4 000 PLN',
    description:
      'Stary program przestał działać? Każda zmiana danych wymaga programisty? Buduję dedykowaną aplikację z interfejsem graficznym. Jeden plik, zero instalacji, zero czekania na IT.',
    tags: ['Python', 'tkinter', 'SQL Server'],
    ready: true,
    caseStudy: 'Realizacja: 100 000 wyników kontroli jakości, jeden plik .exe, 12 MB',
  },
  {
    id: 'mcp-server',
    title: 'MCP Server (API→AI)',
    tagline: 'AI z dostępem do Twoich danych',
    price: '2 000–3 000 PLN',
    description:
      'Chcesz pytać o wyniki firmy jak w zwykłej rozmowie? Buduję połączenie między AI a Twoim systemem. Pytasz po polsku, dostajesz odpowiedź z Twoich własnych danych.',
    tags: ['MCP', 'Python', 'AI', 'Claude'],
    ready: true,
  },
  {
    id: 'arkusze-duchy',
    title: 'Arkusze Duchy',
    tagline: 'Kontrola nad arkuszami, które jakoś działają',
    price: '2 000–5 000 PLN',
    description:
      'Masz arkusze Excel odziedziczone po poprzednim pracowniku? Nikt nie wie jak działają? Przejmuję kontrolę: dokumentuję, naprawiam, eliminuję ryzyko awarii.',
    tags: ['Excel', 'VBA', 'Python', 'Dokumentacja'],
    ready: false,
  },
  {
    id: 'audyt-jakosci-danych',
    title: 'Audyt Jakości Danych',
    tagline: 'Sprawdzam Twoje dane, zanim one sprawdzą Ciebie',
    price: '1 500–3 000 PLN',
    description:
      'Duplikaty, luki, niespójności między systemami. Dostarczam raport z konkretnymi rekomendacjami. Lepiej wiedzieć teraz niż podczas kluczowej decyzji.',
    tags: ['Python', 'Pandas', 'SQL', 'Analiza'],
    ready: false,
  },
];
---

<section id="uslugi" class="px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <!-- Section header -->
    <div class="mb-12">
      <span class="font-mono text-xs text-[#D97706]">// usługi</span>
      <h2 class="mt-2 text-3xl font-bold text-[#E8E3D9] md:text-4xl">
        Co mogę dla Ciebie zbudować
      </h2>
      <p class="mt-3 text-[#8A8480]">
        Pomagam firmom produkcyjnym zamienić dane w decyzje — przez automatyzację i AI.
        Ceny wejściowe — końcowa zależy od skali.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {services.map((s) => (
        <div data-animate class="group flex flex-col rounded border border-[#1E1E1E] bg-[#111111] p-5 transition-all duration-200 hover:-translate-y-1 hover:border-[#D97706]/30 hover:bg-[#131313] hover:shadow-[0_4px_24px_rgba(217,119,6,0.07)]">
          <!-- Top -->
          <div class="flex items-start justify-between gap-2">
            <div>
              <h3 class="font-mono text-base font-semibold text-[#E8E3D9]">{s.title}</h3>
              <p class="mt-0.5 font-mono text-xs text-[#8A8480]">{s.tagline}</p>
            </div>
            {s.ready ? (
              <span class="shrink-0 rounded-full bg-[#D97706]/10 px-2 py-0.5 font-mono text-xs text-[#D97706]">
                gotowe
              </span>
            ) : (
              <span class="shrink-0 rounded-full bg-[#1E1E1E] px-2 py-0.5 font-mono text-xs text-[#8A8480]">
                wkrótce
              </span>
            )}
          </div>

          <!-- Description -->
          <p class="mt-3 flex-1 text-sm leading-relaxed text-[#8A8480]">{s.description}</p>

          {s.caseStudy && (
            <div class="mt-3 rounded bg-[#0C0C0C] px-3 py-2">
              <p class="font-mono text-xs text-[#D97706]">→ {s.caseStudy}</p>
            </div>
          )}

          <!-- Footer -->
          <div class="mt-4 flex items-center justify-between border-t border-[#1E1E1E] pt-3">
            <span class="font-mono text-sm font-semibold text-[#E8E3D9]">{s.price}</span>
            <div class="flex flex-wrap gap-1">
              {s.tags.map((tag) => (
                <span class="rounded bg-[#0C0C0C] px-1.5 py-0.5 font-mono text-xs text-[#8A8480]">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-10 text-center">
      <a
        href="/kontakt"
        class="inline-block rounded bg-[#D97706] px-8 py-3 font-mono text-sm font-semibold text-[#0C0C0C] transition-all hover:bg-[#F59E0B]"
      >
        Porozmawiajmy o Twoim problemie
      </a>
    </div>
  </div>
</section>
